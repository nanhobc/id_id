<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>미니 웹게임 - Dodge</title>
  <style>
    html, body { margin:0; padding:0; height:100%; background:#111; color:#fff; font-family:system-ui, sans-serif; }
    #wrap { display:flex; flex-direction:column; height:100%; }
    #topbar { padding:10px 12px; display:flex; gap:12px; align-items:center; justify-content:space-between; }
    #hud { display:flex; gap:14px; align-items:center; flex-wrap:wrap; }
    #btns { display:flex; gap:8px; align-items:center; }
    button { cursor:pointer; border:0; border-radius:10px; padding:10px 12px; background:#2a2a2a; color:#fff; }
    button:hover { background:#3a3a3a; }
    #game { width:100%; height:100%; display:block; background:#000; }
    #help { opacity:.85; font-size:13px; }
    .pill { padding:6px 10px; border-radius:999px; background:#1f1f1f; }
    /* 모바일 터치 조작 */
    #touchPad {
      position: fixed; right: 14px; bottom: 14px;
      width: 160px; height: 160px; border-radius: 18px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      display:none;
      touch-action:none;
    }
    #stick {
      position:absolute; left:50%; top:50%;
      width:56px; height:56px; margin-left:-28px; margin-top:-28px;
      border-radius: 999px;
      background: rgba(255,255,255,0.18);
      border: 1px solid rgba(255,255,255,0.20);
    }
    @media (pointer: coarse) {
      #touchPad { display:block; }
    }
  </style>
</head>
<body>
  <div id="wrap">
    <div id="topbar">
      <div id="hud">
        <div class="pill">점수: <b id="score">0</b></div>
        <div class="pill">최고: <b id="best">0</b></div>
        <div class="pill">상태: <b id="state">대기</b></div>
        <div id="help">조작: ←↑↓→ / WASD (모바일: 오른쪽 조이스틱)</div>
      </div>
      <div id="btns">
        <button id="startBtn">시작/재시작</button>
        <button id="pauseBtn">일시정지</button>
      </div>
    </div>
    <canvas id="game"></canvas>
  </div>

  <div id="touchPad" aria-label="touch joystick">
    <div id="stick"></div>
  </div>

<script>
/**
 * 미니 게임: 플레이어(사각형)를 움직여서 떨어지는 장애물을 피하면 점수가 오릅니다.
 * - 충돌하면 게임 오버
 * - 시간이 지날수록 난이도 상승(스폰/속도 증가)
 */

(() => {
  // ===== 캔버스/리사이즈 =====
  const canvas = document.getElementById("game");
  const ctx = canvas.getContext("2d");

  function resizeCanvas() {
    const dpr = Math.max(1, window.devicePixelRatio || 1);
    canvas.width = Math.floor(canvas.clientWidth * dpr);
    canvas.height = Math.floor((window.innerHeight - document.getElementById("topbar").offsetHeight) * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0); // CSS 픽셀 기준으로 그리기
  }
  window.addEventListener("resize", resizeCanvas);
  resizeCanvas();

  // ===== HUD =====
  const elScore = document.getElementById("score");
  const elBest  = document.getElementById("best");
  const elState = document.getElementById("state");

  // 로컬스토리지 최고점
  const BEST_KEY = "mini_dodge_best";
  let best = Number(localStorage.getItem(BEST_KEY) || 0);
  elBest.textContent = best;

  // ===== 게임 상태 =====
  const state = {
    running: false,
    paused: false,
    gameOver: false,
    t: 0,
    score: 0,
    lastTime: performance.now(),
  };

  // ===== 플레이어 =====
  const player = {
    x: 0, y: 0,
    w: 28, h: 28,
    speed: 320, // px/s
    vx: 0, vy: 0
  };

  // ===== 장애물 =====
  const obstacles = [];
  function spawnObstacle() {
    const w = rand(14, 44);
    const h = rand(14, 44);
    const x = rand(0, canvas.clientWidth - w);
    const y = -h - 10;
    const base = 140 + Math.min(220, state.t * 10); // 시간이 지날수록 빨라짐
    const vy = rand(base, base + 220);
    obstacles.push({ x, y, w, h, vy });
  }

  // 스폰 조절(난이도)
  let spawnTimer = 0;

  // ===== 입력(키보드) =====
  const keys = new Set();
  window.addEventListener("keydown", (e) => {
    if (["ArrowUp","ArrowDown","ArrowLeft","ArrowRight"," ","w","a","s","d","W","A","S","D"].includes(e.key)) {
      e.preventDefault();
    }
    keys.add(e.key);
    // 스페이스로 시작/재시작
    if (e.key === " ") {
      if (!state.running || state.gameOver) startGame();
      else togglePause();
    }
  });
  window.addEventListener("keyup", (e) => keys.delete(e.key));

  // ===== 입력(모바일 조이스틱) =====
  const touchPad = document.getElementById("touchPad");
  const stick = document.getElementById("stick");
  let touchActive = false;
  let touchCenter = { x: 0, y: 0 };
  let touchVec = { x: 0, y: 0 };

  function setStick(dx, dy) {
    // stick 이동을 보기 좋게 제한
    const max = 46;
    const len = Math.hypot(dx, dy);
    if (len > max) { dx = dx/len*max; dy = dy/len*max; }
    stick.style.transform = `translate(${dx}px, ${dy}px)`;
  }

  touchPad.addEventListener("pointerdown", (e) => {
    touchActive = true;
    touchPad.setPointerCapture(e.pointerId);
    const rect = touchPad.getBoundingClientRect();
    touchCenter = { x: rect.left + rect.width/2, y: rect.top + rect.height/2 };
    onTouchMove(e);
    if (!state.running || state.gameOver) startGame();
  });

  function onTouchMove(e) {
    if (!touchActive) return;
    const dx = e.clientX - touchCenter.x;
    const dy = e.clientY - touchCenter.y;
    // -1~1 범위로 정규화
    const max = 60;
    touchVec.x = clamp(dx / max, -1, 1);
    touchVec.y = clamp(dy / max, -1, 1);
    setStick(dx, dy);
  }

  touchPad.addEventListener("pointermove", onTouchMove);
  touchPad.addEventListener("pointerup", () => {
    touchActive = false;
    touchVec = { x: 0, y: 0 };
    stick.style.transform = "translate(0px, 0px)";
  });
  touchPad.addEventListener("pointercancel", () => {
    touchActive = false;
    touchVec = { x: 0, y: 0 };
    stick.style.transform = "translate(0px, 0px)";
  });

  // ===== 버튼 =====
  document.getElementById("startBtn").addEventListener("click", startGame);
  document.getElementById("pauseBtn").addEventListener("click", togglePause);

  function togglePause() {
    if (!state.running || state.gameOver) return;
    state.paused = !state.paused;
    elState.textContent = state.paused ? "일시정지" : "진행중";
    // 일시정지 후 프레임 시간 튐 방지
    state.lastTime = performance.now();
  }

  // ===== 게임 시작/리셋 =====
  function startGame() {
    state.running = true;
    state.paused = false;
    state.gameOver = false;
    state.t = 0;
    state.score = 0;
    spawnTimer = 0;
    obstacles.length = 0;

    // 플레이어 중앙 배치
    player.x = canvas.clientWidth / 2 - player.w / 2;
    player.y = canvas.clientHeight - 80;
    player.vx = 0; player.vy = 0;

    elScore.textContent = "0";
    elState.textContent = "진행중";
    state.lastTime = performance.now();
  }

  // ===== 루프 =====
  function loop(now) {
    requestAnimationFrame(loop);

    if (!state.running) {
      drawIdle();
      return;
    }
    if (state.paused) {
      drawPaused();
      return;
    }
    if (state.gameOver) {
      drawGameOver();
      return;
    }

    // dt 계산
    const dt = Math.min(0.033, (now - state.lastTime) / 1000);
    state.lastTime = now;
    state.t += dt;

    update(dt);
    draw();
  }
  requestAnimationFrame(loop);

  function update(dt) {
    // 키보드 입력 → 방향 벡터 만들기
    let ix = 0, iy = 0;
    if (keys.has("ArrowLeft") || keys.has("a") || keys.has("A")) ix -= 1;
    if (keys.has("ArrowRight")|| keys.has("d") || keys.has("D")) ix += 1;
    if (keys.has("ArrowUp")   || keys.has("w") || keys.has("W")) iy -= 1;
    if (keys.has("ArrowDown") || keys.has("s") || keys.has("S")) iy += 1;

    // 모바일 조이스틱 반영(키보드와 합산)
    ix += touchVec.x;
    iy += touchVec.y;

    // 대각선 속도 보정
    const len = Math.hypot(ix, iy);
    if (len > 1e-6) { ix /= Math.max(1, len); iy /= Math.max(1, len); }

    player.vx = ix * player.speed;
    player.vy = iy * player.speed;

    player.x += player.vx * dt;
    player.y += player.vy * dt;

    // 화면 밖 못 나가게
    player.x = clamp(player.x, 0, canvas.clientWidth - player.w);
    player.y = clamp(player.y, 0, canvas.clientHeight - player.h);

    // 장애물 스폰 (시간 지날수록 더 자주)
    const spawnInterval = Math.max(0.12, 0.55 - state.t * 0.02);
    spawnTimer += dt;
    while (spawnTimer >= spawnInterval) {
      spawnTimer -= spawnInterval;
      spawnObstacle();
      // 랜덤 추가 스폰(후반)
      if (state.t > 10 && Math.random() < 0.25) spawnObstacle();
    }

    // 장애물 이동/정리
    for (const o of obstacles) o.y += o.vy * dt;
    // 화면 아래로 나간 것 제거
    for (let i = obstacles.length - 1; i >= 0; i--) {
      if (obstacles[i].y > canvas.clientHeight + 80) obstacles.splice(i, 1);
    }

    // 충돌 체크
    for (const o of obstacles) {
      if (rectHit(player, o)) {
        onGameOver();
        break;
      }
    }

    // 점수: 생존 시간 기반
    state.score += dt * 10;
    elScore.textContent = String(Math.floor(state.score));
  }

  function onGameOver() {
    state.gameOver = true;
    elState.textContent = "게임오버";
    const finalScore = Math.floor(state.score);
    if (finalScore > best) {
      best = finalScore;
      localStorage.setItem(BEST_KEY, String(best));
      elBest.textContent = String(best);
    }
  }

  // ===== 그리기 =====
  function clear() {
    ctx.clearRect(0, 0, canvas.clientWidth, canvas.clientHeight);
  }

  function drawBackground() {
    // 간단한 그리드
    const w = canvas.clientWidth, h = canvas.clientHeight;
    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, w, h);

    ctx.globalAlpha = 0.18;
    ctx.strokeStyle = "#fff";
    ctx.lineWidth = 1;
    const step = 40;
    for (let x = 0; x <= w; x += step) {
      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, h); ctx.stroke();
    }
    for (let y = 0; y <= h; y += step) {
      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(w, y); ctx.stroke();
    }
    ctx.globalAlpha = 1;
  }

  function draw() {
    clear();
    drawBackground();

    // 장애물
    ctx.fillStyle = "#ff4d4d";
    for (const o of obstacles) ctx.fillRect(o.x, o.y, o.w, o.h);

    // 플레이어
    ctx.fillStyle = "#4dd2ff";
    ctx.fillRect(player.x, player.y, player.w, player.h);

    // 상단 안내 텍스트(캔버스 내부)
    ctx.fillStyle = "rgba(255,255,255,0.85)";
    ctx.font = "14px system-ui, sans-serif";
    ctx.fillText("빨간 네모 피하기!", 12, 22);
  }

  function drawIdle() {
    clear();
    drawBackground();
    centerText("시작 버튼 또는 스페이스로 시작", 0);
    centerText("←↑↓→ / WASD로 이동", 24);
  }

  function drawPaused() {
    draw();
    ctx.fillStyle = "rgba(0,0,0,0.55)";
    ctx.fillRect(0, 0, canvas.clientWidth, canvas.clientHeight);
    centerText("일시정지", 0);
    centerText("스페이스 또는 버튼으로 재개", 24);
  }

  function drawGameOver() {
    draw();
    ctx.fillStyle = "rgba(0,0,0,0.6)";
    ctx.fillRect(0, 0, canvas.clientWidth, canvas.clientHeight);
    centerText("게임 오버", 0);
    centerText(`점수: ${Math.floor(state.score)} / 최고: ${best}`, 24);
    centerText("시작 버튼 또는 스페이스로 재시작", 48);
  }

  function centerText(text, yOffset) {
    ctx.fillStyle = "rgba(255,255,255,0.92)";
    ctx.font = "20px system-ui, sans-serif";
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText(text, canvas.clientWidth / 2, canvas.clientHeight / 2 + yOffset);
    ctx.textAlign = "left";
    ctx.textBaseline = "alphabetic";
  }

  // ===== 유틸 =====
  function clamp(v, a, b) { return Math.max(a, Math.min(b, v)); }
  function rand(a, b) { return a + Math.random() * (b - a); }
  function rectHit(a, b) {
    return a.x < b.x + b.w && a.x + a.w > b.x && a.y < b.y + b.h && a.y + a.h > b.y;
  }
})();
</script>
</body>
</html>
